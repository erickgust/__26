{
  "name": "__26",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "typescript": "6.0.3"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:native": "turbo -F native dev",
    "dev:web": "turbo -F web dev",
    "deploy:web": "turbo -F web deploy",
    "check": "oxlint && oxfmt --write"
  },
  "devDependencies": {
    "@__26/config": "workspace:*",
    "lefthook": "2.1.6",
    "oxfmt": "0.49.0",
    "oxlint": "1.64.0",
    "turbo": "2.9.12",
    "typescript": "catalog:"
  },
  "packageManager": "bun@1.3.6"
}
