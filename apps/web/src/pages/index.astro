---
import Layout from "../layouts/Layout.astro";
import TITLE_TEXT from "../ascii.txt?raw";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import * as Project from "../components/Project";
import { SITE } from "../data/site";
import ImageQSMP from "../assets/images/qsmp.png";
import ImageTMDB from "../assets/images/tmdb.png";
import ImageMyContacts from "../assets/images/mycontacts.png";

import FaleLogo from "../assets/experiences/falecomigo.svg";
import QuackSLogo from "../assets/experiences/quacks.svg";
import UpLogo from "../assets/experiences/up.svg";
import UniLogo from "../assets/experiences/uni.svg";
import * as Experience from "../components/Experience";
---

<Layout title={SITE.title}>
  <section
    aria-label="Introduction"
    class="h-svh flex flex-col gap-8 justify-between"
  >
    <Header />
    <pre
      aria-hidden="true"
      role="img"
      class="hidden lg:block w-full text-center select-none overflow-hidden">{TITLE_TEXT}</pre>
  </section>

  <main
    id="main-content"
    class="bg-white text-black py-16 space-y-16 selection:text-white selection:bg-blue"
  >
    <section id="projects" class="max-w-266 mx-auto space-y-8 scroll-mt-8">
      <h2 class="sr-only">Projects</h2>

      <Project.Root>
        <Project.Header
          tech="Tailwind + TypeScript + Next.js"
          href="https://qsmpco.netlify.app/"
          label="Live Site"
        />
        <Project.Body>
          <Project.Title>QSMP.co</Project.Title>
          <Project.Description>
            <p>
              The official portal of the QSMP project, a multilingual Minecraft
              server with real-time translation, connecting content creators
              from different regions and languages.
            </p>
            <p>
              The website's goal was to centralize the main information about
              the server and its participants, as well as sections dedicated to
              project updates.
            </p>
          </Project.Description>
          <Project.Preview src={ImageQSMP} alt="QSMP website preview" />
        </Project.Body>
      </Project.Root>

      <Project.Root>
        <Project.Header
          tech="React.js + TypeScript + Tailwind"
          href="https://erickgust-tmdb.netlify.app/"
          label="Live Site"
        />
        <Project.Body>
          <Project.Title>TMDB Movies</Project.Title>
          <Project.Description>
            <p>
              TMDB Movies is a project that lets you browse a list of trending
              movies, filtered by various genres. By selecting a movie, you can
              view details such as rating, synopsis, cast, genres, and
              certification.
            </p>
            <p>
              built in TypeScript and React to explore React Query features
              combined with React Router.
            </p>
          </Project.Description>
          <Project.Preview src={ImageTMDB} alt="TMDB Movies website preview" />
        </Project.Body>
      </Project.Root>

      <Project.Root>
        <Project.Header
          tech="React.js + TypeScript + Node.js"
          href="https://github.com/erickgust/my-contacts-front/"
          label="Repository"
        />
        <Project.Body>
          <Project.Title>MyContacts</Project.Title>
          <Project.Description>
            <p>
              MyContacts was a project where I explored React and React Router
              more in-depth by building a contact management feature, as well as
              organize them by categories.
            </p>
            <p>
              I also had the opportunity to develop a REST API in Node.js with
              Express, which connects to a Docker environment running
              PostgreSQL.
            </p>
          </Project.Description>
          <Project.Preview
            src={ImageMyContacts}
            alt="MyContacts website preview"
          />
        </Project.Body>
      </Project.Root>
    </section>

    <section
      id="experiences"
      class="max-w-266 mx-auto space-y-8 scroll-mt-8 px-6 lg:px-0"
    >
      <h2 class="sr-only">Experiences</h2>

      <Experience.Root>
        <Experience.Header>
          <Experience.Info title="falecomigo.ai" role="Frontend developer">
            <FaleLogo class="size-12 shrink-0" aria-hidden="true" />
          </Experience.Info>
          <Experience.Period from="2025" />
        </Experience.Header>
        <Experience.Body>
          <Experience.Description>
            At falecomigo.ai, I worked on the main platform and built the
            WhatsApp Web integration plugin, a feature that brought the
            company's AI automation tools directly into the WhatsApp interface,
            helping businesses turn messaging conversations into sales and
            customer engagement opportunities.
          </Experience.Description>
        </Experience.Body>
      </Experience.Root>

      <Experience.Root>
        <Experience.Header>
          <Experience.Info title="Quackity Studios" role="Frontend developer">
            <QuackSLogo class="size-12 shrink-0" aria-hidden="true" />
          </Experience.Info>
          <Experience.Period from="2023" to="2024" />
        </Experience.Header>
        <Experience.Body>
          <Experience.Description>
            As part of an international team, I contributed to multilingual
            projects built with Next.js and TypeScript, designed to handle high
            volumes of simultaneous users, with a strong focus on optimizing
            user experience and performance.
          </Experience.Description>
        </Experience.Body>
      </Experience.Root>

      <Experience.Root>
        <Experience.Header>
          <Experience.Info title="UpBase Consultoria" role="Frontend Intern">
            <UpLogo class="size-12 shrink-0" aria-hidden="true" />
          </Experience.Info>
          <Experience.Period from="2022" to="2023" />
        </Experience.Header>
        <Experience.Body>
          <Experience.Description>
            At UpBase, I demonstrated my expertise in NextJS, React Native and
            TypeScript by contributing to the development of mobile and web
            projects. I worked closely with client feedback to align with their
            needs and consistently deliver results.
          </Experience.Description>
        </Experience.Body>
      </Experience.Root>

      <Experience.Root>
        <Experience.Header>
          <Experience.Info
            title="Universidade Cesumar"
            role="Associate Degree in Software Development"
          >
            <UniLogo class="size-12 shrink-0" aria-hidden="true" />
          </Experience.Info>
          <Experience.Period from="2022" to="2025" />
        </Experience.Header>
        <Experience.Body>
          <Experience.Description>
            I gained hands-on experience across the full software development
            lifecycle, from requirements gathering to deployment and
            maintenance. I also worked on interface design from wireframes to
            high-fidelity prototypes, and strengthened my skills in algorithms,
            data structures (Java, C), and database management with MySQL.
          </Experience.Description>
        </Experience.Body>
      </Experience.Root>
    </section>
  </main>

  <Footer />
</Layout>
