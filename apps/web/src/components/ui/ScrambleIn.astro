---
interface Props {
  text: string;
  className?: string;
  trigger?: "scroll" | "immediate";
}

const { text, className = "", trigger = "scroll" } = Astro.props;

const visibleClassName = ["inline-block whitespace-pre-wrap", className]
  .filter(Boolean)
  .join(" ");
---

<span class="sr-only">{text}</span>
<span
  aria-hidden="true"
  class={visibleClassName}
  data-scramble
  data-scramble-mode="intro"
  data-scramble-text={text}
  data-scramble-trigger={trigger}
>
  {text}
</span>

<script>
  import "../../scripts/scramble-text";
</script>
