---
interface Props {
  text: string;
  className?: string;
  trigger?: "scroll" | "immediate";
  from?: "left" | "right" | "center" | "random" | "auto";
  direction?: "left" | "right";
  chars?: string;
  duration?: number;
  revealRate?: number;
  settleRate?: number;
  settleDuration?: number;
  revealDelay?: number;
  delay?: number;
  reversed?: boolean;
  cursor?: boolean | number | string;
  perturbation?: number;
  seed?: number;
}

const {
  text,
  className = "",
  trigger = "scroll",
  from,
  direction,
  chars,
  duration,
  revealRate,
  settleRate,
  settleDuration,
  revealDelay,
  delay,
  reversed,
  cursor,
  perturbation,
  seed,
} = Astro.props;

const visibleClassName = ["inline-block whitespace-pre-wrap", className].filter(Boolean).join(" ");
const introFrom = from ?? direction ?? "left";
---

<span class="sr-only">{text}</span>
<span
  aria-hidden="true"
  class={visibleClassName}
  data-scramble
  data-scramble-mode="intro"
  data-scramble-text={text}
  data-scramble-trigger={trigger}
  data-scramble-intro-from={introFrom}
  data-scramble-intro-chars={chars}
  data-scramble-intro-duration={duration}
  data-scramble-intro-reveal-rate={revealRate}
  data-scramble-intro-settle-rate={settleRate}
  data-scramble-intro-settle-duration={settleDuration}
  data-scramble-intro-reveal-delay={revealDelay}
  data-scramble-intro-delay={delay}
  data-scramble-intro-override=""
  data-scramble-intro-reversed={reversed ? "true" : undefined}
  data-scramble-intro-cursor={cursor}
  data-scramble-intro-perturbation={perturbation}
  data-scramble-intro-seed={seed}
>
  {text}
</span>

<script>
  import "../../scripts/scramble-text.js";
</script>
