---
import { SITE } from "../data/site";
import ScrambleIn from "./ui/ScrambleIn.astro";
import ScrambleText from "./ui/ScrambleText.astro";
---

<footer class="bg-black text-white selection:bg-white selection:text-black">
  <div class="h-120 max-w-360 mx-auto py-4 flex flex-col px-6 lg:px-8">
    <div class="grid place-items-center flex-1">
      <div class="text-center">
        <p class="font-light lg:mb-1 text-18 lg:text-xl">
          <ScrambleIn text="( Reach out )" />
        </p>
        <strong class="font-normal text-3xl lg:text-4xl lowercase">
          <a
            class="lg:hidden hover:bg-white hover:text-black"
            href={`mailto:${SITE.email}`}
          >
            <ScrambleIn text={SITE.email} />
          </a>
          <button
            type="button"
            aria-label="Copy email address to clipboard"
            class="hidden lg:inline cursor-pointer after:block after:h-0 after:overflow-hidden after:invisible after:pointer-events-none after:content-[attr(data-copied-label)] hover:bg-white hover:text-black"
            data-email={SITE.email}
            data-default-label={SITE.email}
            data-copied-label="( copied to clipboard )"
            data-failed-label="( failed to copy )"
          >
            <span
              class="inline-block whitespace-pre-wrap"
              data-copy-label
              data-scramble
              data-scramble-mode="intro"
              data-scramble-text={SITE.email}
              data-scramble-trigger="scroll"
              aria-hidden="true">{SITE.email}</span
            >
          </button>
        </strong>
      </div>
    </div>

    <div
      class="flex flex-col lg:flex-row justify-between items-center lg:items-end"
    >
      <div class="flex gap-5 lg:gap-8">
        <a
          class="uppercase cursor-pointer hover:bg-white hover:text-black"
          href={SITE.socials.linkedin}
          target="_blank"
          rel="noopener noreferrer"
        >
          <ScrambleText text="LinkedIn [↗]" />
        </a>
        <a
          class="uppercase cursor-pointer hover:bg-white hover:text-black"
          href={SITE.socials.github}
          target="_blank"
          rel="noopener noreferrer"
        >
          <ScrambleText text="Github [↗]" />
        </a>
      </div>

      <p class="text-end mt-2 lg:mt-0">
        ©<time datetime="2026">2026</time>
        <br class="hidden lg:block" />
        all rights reserved
      </p>
    </div>
  </div>
</footer>

<script>
  import "../scripts/email-copy";
</script>
