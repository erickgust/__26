---
interface Props {
  title: string;
  role: string;
}

const { title, role } = Astro.props;
---

<div class="flex items-center gap-3">
  <slot />

  <div class="flex flex-col gap-0.5">
    <h3 class="font-semibold text-17/5.5">{title}</h3>
    <span class="text-15/none pb-1">{role}</span>
  </div>
</div>
